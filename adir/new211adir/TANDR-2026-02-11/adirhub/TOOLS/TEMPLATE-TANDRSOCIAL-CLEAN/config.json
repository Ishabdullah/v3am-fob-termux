{
  "app": {
    "name": "Knowledge Bot",
    "version": "1.0.0",
    "description": "Knowledge base AI assistant",
    "environment": "production",
    "access": "employee-only"
  },
  "llm": {
    "provider": "llamacpp",
    "anthropic": {
      "api_key": "",
      "model": "claude-haiku-4-5-20251001",
      "max_tokens": 4096,
      "temperature": 0.7
    },
    "gemini": {
      "api_key": "",
      "model": "gemini-2.0-flash",
      "max_tokens": 8192,
      "temperature": 0.7
    },
    "fallback": {
      "enabled": false,
      "provider": "anthropic"
    },
    "llamacpp": {
      "endpoint": "http://127.0.0.1:8084/completion",
      "model": "default",
      "max_tokens": 4096,
      "temperature": 0.7
    }
  },
  "security": {
    "allowed_read_dirs": [
      "data/social-knowledge",
      "adir/logs/fb-feeds",
      "adir/logs/post-queue"
    ],
    "allowed_write_dirs": [
      "adir/logs",
      "adir/logs/post-drafts",
      "adir/logs/fb-feeds",
      "adir/logs/post-queue",
      "data/social-knowledge"
    ],
    "allowed_read_extensions": [
      ".md",
      ".txt",
      ".json"
    ],
    "allowed_write_extensions": [
      ".txt",
      ".json",
      ".md"
    ],
    "rate_limit": {
      "enabled": true,
      "requests_per_minute": 60,
      "requests_per_hour": 500,
      "requests_per_day": 2000
    },
    "cors": {
      "enabled": true,
      "allowed_origins": [
        "*"
      ]
    }
  },
  "knowledge": {
    "base_path": "data/social-knowledge",
    "auto_refresh": true,
    "cache_ttl": 300,
    "max_context_files": 20,
    "file_scan_on_start": true
  },
  "conversation": {
    "max_history": 30,
    "max_message_length": 5000,
    "log_conversations": true,
    "log_path": "adir/logs/conversations.txt",
    "session_timeout": 3600
  },
  "system_prompt": {
    "role": "You are a knowledge bot deployed on the FOB platform by V3AM. You answer questions from your loaded knowledge files. If no knowledge files have been loaded yet, let the user know and suggest they add .md files to the data/knowledge directory.\n\nHOW YOU WORK\n- Your knowledge files are your primary source \u2014 answer from them first\n- Be specific and direct \u2014 cite what is documented, not what you assume\n- If something is not in your knowledge files, say so honestly\n- Keep answers focused and useful\n\nWHAT YOU ARE\n- A specialized knowledge bot built for a specific purpose\n- Part of the FOB multi-agent fleet\n- Accessible via the TANDRmgr relay at your assigned service key\n\nWHAT YOU ARE NOT\n- A general-purpose assistant\n- Able to access the internet or external systems unless configured\n- Able to take actions outside of answering questions from your knowledge base\n\n--- CUSTOMIZE BELOW THIS LINE ---\nYou specialize in: [topic or domain]\nYour audience is: [who will be talking to you]\nYour tone should be: [direct / friendly / technical / etc.]\nKey things you should always mention: [any required context or disclaimers]",
    "instructions": [
      "Ground all answers in the loaded knowledge files",
      "Use [LIST_FILES] and [READ_FILE] to browse and verify information",
      "Save useful notes and drafts with [SAVE_FILE]",
      "Be honest when a topic is not covered in the knowledge base",
      "Use markdown formatting for readability",
      "Always explain your reasoning when making recommendations"
    ],
    "restrictions": [
      "Do not invent facts not present in the knowledge files",
      "Do not access external systems or APIs",
      "Do not share API tokens or credentials",
      "Do not execute system commands",
      "Only read and write within the allowed directories"
    ]
  },
  "ui": {
    "theme": "professional",
    "brand_color": "#00d9ff",
    "background_color": "#0a0e27",
    "show_typing_indicator": true,
    "markdown_enabled": true,
    "code_highlighting": true,
    "max_messages_displayed": 50,
    "auto_scroll": true,
    "timestamp_format": "HH:mm"
  },
  "logging": {
    "enabled": true,
    "level": "info",
    "log_errors": true,
    "log_conversations": true,
    "log_analytics": true,
    "error_log_path": "adir/logs/errors.txt",
    "analytics_log_path": "adir/logs/analytics.txt"
  },
  "analytics": {
    "enabled": true,
    "track_conversations": true,
    "track_response_time": true,
    "track_user_agents": true,
    "track_drafts_created": true,
    "track_research_queries": true
  },
  "features": {
    "markdown_rendering": true,
    "code_blocks": true,
    "file_upload": false,
    "image_support": false,
    "voice_input": false,
    "suggestions": true,
    "graph_api": true
  },
  "facebook_graph_api": {
    "enabled": true,
    "api_version": "v21.0",
    "page_id": "YOUR_FACEBOOK_PAGE_ID",
    "access_token": "YOUR_FACEBOOK_ACCESS_TOKEN",
    "permissions": [
      "pages_read_engagement",
      "pages_manage_posts",
      "read_insights"
    ],
    "endpoints": {
      "page_feed": "/YOUR_FACEBOOK_PAGE_ID/feed",
      "page_posts": "/YOUR_FACEBOOK_PAGE_ID/posts",
      "page_insights": "/YOUR_FACEBOOK_PAGE_ID/insights",
      "search": "/search"
    },
    "rate_limits": {
      "calls_per_hour": 200,
      "burst_limit": 50
    },
    "feed_monitoring": {
      "enabled": false,
      "check_interval_minutes": 60,
      "pages_to_monitor": [
        "YOUR_FACEBOOK_PAGE_ID"
      ],
      "keywords_to_track": [
        "construction",
        "remodeling",
        "home improvement",
        "contractor",
        "renovation"
      ]
    }
  }
}